{
  "name": "@easy-genomics/root",
  "description": "Easy Genomics web application to help simplify genomic analysis of sequenced genetic data for bioinformaticians utilizing AWS HealthOmics & NextFlow Tower",
  "scripts": {
    "clobber": "pnpm exec projen clobber",
    "compile": "pnpm exec projen compile",
    "default": "pnpm exec projen default",
    "eject": "pnpm exec projen eject",
    "eslint": "pnpm exec projen eslint",
    "package": "pnpm exec projen package",
    "post-compile": "pnpm exec projen post-compile",
    "post-upgrade": "pnpm exec projen post-upgrade",
    "pre-compile": "pnpm exec projen pre-compile",
    "test": "pnpm exec projen test",
    "test:watch": "pnpm exec projen test:watch",
    "upgrade": "pnpm dlx projen upgrade && pnpm nx run-many --targets=upgrade --projects=@easy-genomics/shared-lib,@easy-genomics/back-end,@easy-genomics/front-end",
    "watch": "pnpm exec projen watch",
    "projen": "nx reset; pnpm exec projen",
    "build-back-end": "pnpm nx run-many --targets=build --projects=@easy-genomics/shared-lib,@easy-genomics/back-end --verbose=true --outputStyle=stream",
    "build-front-end": "nx reset && pnpm nx run-many --targets=build --projects=@easy-genomics/shared-lib,@easy-genomics/front-end --verbose=true",
    "build-and-deploy": "pnpm nx run-many --targets=build --projects=@easy-genomics/shared-lib,@easy-genomics/back-end --verbose=true --outputStyle=stream && pnpm nx run-many --targets=deploy --projects=@easy-genomics/back-end --verbose=true --outputStyle=stream && pnpm nx run-many --targets=build --projects=@easy-genomics/shared-lib,@easy-genomics/front-end --verbose=true --outputStyle=stream && pnpm nx run-many --targets=deploy --projects=@easy-genomics/front-end --verbose=true --outputStyle=stream",
    "prettier": "prettier --write '{**/*,*}.{js,ts,vue,scss,json,md,html,mdx}'",
    "cicd-build-deploy-back-end": "export CI_CD=true NX_SKIP_NX_CACHE=true && pnpm nx run-many --targets=build --projects=@easy-genomics/shared-lib,@easy-genomics/back-end --verbose=true --outputStyle=stream && pnpm nx run-many --targets=deploy --projects=@easy-genomics/back-end --verbose=true --outputStyle=stream",
    "cicd-build-deploy-front-end": "export CI_CD=true NX_SKIP_NX_CACHE=true && pnpm nx run-many --targets=build --projects=@easy-genomics/shared-lib,@easy-genomics/front-end --verbose=true --outputStyle=stream && pnpm nx run-many --targets=deploy --projects=@easy-genomics/front-end --verbose=true --outputStyle=stream",
    "prepare": "husky || true",
    "pre-commit": "lint-staged"
  },
  "author": {
    "name": "DEPT Agency",
    "organization": true
  },
  "devDependencies": {
    "@aws-sdk/types": "^3.775.0",
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@commitlint/cz-commitlint": "^18.6.1",
    "@nrwl/devkit": "^15",
    "@nrwl/workspace": "^15",
    "@types/aws-lambda": "^8.10.149",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "@useoptic/optic": "^1.0.9",
    "aws-sdk-client-mock": "^3.1.0",
    "aws-sdk-client-mock-jest": "^3.1.0",
    "constructs": "^10.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.10.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.0",
    "nx": "^15",
    "prettier": "^3.5.3",
    "projen": "^0.88.9",
    "ts-jest": "^29.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "validate-branch-name": "^1.3.2"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=6.27.0 <7.0.0",
      "form-data": ">=4.0.6",
      "dompurify": ">=3.4.11",
      "tar": ">=7.5.16",
      "protobufjs": ">=7.6.3 <8.0.0",
      "js-yaml": ">=4.1.1",
      "shell-quote": ">=1.8.4",
      "simple-git": ">=3.36.0",
      "fast-xml-parser": ">=5.7.0",
      "@aws-amplify/storage>fast-xml-parser": ">=4.5.5 <5.0.0",
      "minimatch": ">=9.0.7 <10.0.0",
      "eslint-plugin-import>minimatch": ">=3.1.2 <4.0.0",
      "node-forge": ">=1.4.0",
      "ws": ">=8.21.0",
      "picomatch": ">=4.0.4",
      "flatted": ">=3.4.2",
      "defu": ">=6.1.5",
      "immutable": ">=5.1.5",
      "jws": ">=3.2.3 <4.0.0",
      "js-cookie": ">=3.0.7",
      "glob": ">=10.5.0",
      "koa": ">=2.16.4",
      "fast-xml-builder": ">=1.1.7",
      "svgo": ">=3.3.3",
      "lodash": ">=4.17.23",
      "serialize-javascript": ">=7.0.5",
      "qs": ">=6.15.2",
      "brace-expansion": ">=2.0.3",
      "bn.js": ">=5.2.3",
      "yaml": ">=2.8.3",
      "nanoid": ">=3.3.8",
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1 <12.0.0",
      "joi": ">=17.13.4",
      "launch-editor": ">=2.14.1",
      "diff": ">=8.0.3",
      "cookie": ">=0.7.0",
      "on-headers": ">=1.1.0"
    }
  },
  "engines": {
    "node": ">= 20.15.0"
  },
  "main": "lib/index.js",
  "license": "Apache-2.0",
  "homepage": "https://github.com/twobulls/easy-genomics",
  "version": "0.0.0",
  "jest": {
    "coverageProvider": "v8",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/../../$1",
      "^@BE/(.*)$": "<rootDir>/packages/back-end/src/app/$1",
      "^@FE/(.*)$": "<rootDir>/packages/front-end/src/app/$1",
      "^@SharedLib/(.*)$": "<rootDir>/packages/shared-lib/src/app/$1"
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "<rootDir>/@(src|test)/**/*(*.)@(spec|test).ts?(x)",
      "<rootDir>/@(src|test)/**/__tests__/**/*.ts?(x)",
      "<rootDir>/@(projenrc)/**/*(*.)@(spec|test).ts?(x)",
      "<rootDir>/@(projenrc)/**/__tests__/**/*.ts?(x)"
    ],
    "clearMocks": true,
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "lcov",
      "clover",
      "cobertura",
      "text"
    ],
    "coverageDirectory": "coverage",
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "watchPathIgnorePatterns": [
      "/node_modules/"
    ],
    "reporters": [
      "default"
    ],
    "transform": {
      "^.+\\.[t]sx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.dev.json"
        }
      ]
    }
  },
  "types": "lib/index.d.ts",
  "lint-staged": {
    "{**/*,*}.{js,ts,vue,scss,json,md,html,mdx}": [
      "prettier --write"
    ],
    "packages/front-end/src/**/*.{js,ts}": [
      "pnpm --prefix packages/front-end run lint"
    ],
    "packages/back-end/src/**/*.{js,ts}": [
      "pnpm --prefix packages/back-end run lint"
    ],
    "packages/shared-lib/src/**/*.{js,ts}": [
      "pnpm --prefix packages/shared-lib run lint"
    ]
  },
  "packageManager": "pnpm@9.15.0",
  "//": "~~ Generated by projen. To modify, edit .projenrc.ts and run \"pnpm exec projen\"."
}
